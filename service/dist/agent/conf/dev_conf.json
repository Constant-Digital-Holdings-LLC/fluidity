{
    "targets": [
        {
            "location": "https://localhost:3000/FIFO",
            "key": "184f451d98b79137dcb014abda5eb6c9"
        }
    ],
    "site": "MyOffice",
    "logLevel": "debug",
    "collectors": [
        {
            "description": "Agent Report",
            "plugin": "vRep",
            "pollIntervalSec": 3600
        },
        {
            "description": "Net Watcher",
            "plugin": "hamLive",
            "enabled": false,
            "url": "https://www.ham.live/api/data/livenets",
            "pollIntervalSec": 60,
            "notifyIntervalSec": 120
        },
        {
            "description": "SRS",
            "plugin": "srsSerial",
            "path": "sim://srs",
            "baudRate": 9600,
            "keepRaw": true,
            "extendedOptions": {
                "portmap": [
                    "440",
                    "2M",
                    "L1-PV Switch",
                    "L2-South Mtn",
                    "L3-TBD-OFF",
                    "L4-Saddle",
                    "L5-Sulphur",
                    "L6-San Pedro"
                ]
            }
        },
        {
            "description": "TNC",
            "plugin": "genericSerial",
            "path": "sim://generic",
            "baudRate": 9600
        },
        {
            "description": "LAN Sensors",
            "plugin": "udpStruct",
            "port": 17996,
            "bind": "127.0.0.1"
        },
        {
            "description": "System Log (example - any growing log file)",
            "plugin": "logTail",
            "enabled": false,
            "path": "/var/log/syslog",
            "fromStart": false,
            "extendedOptions": {
                "tokenize": {
                    "format": "auto"
                }
            }
        },
        {
            "description": "Webhook Gateway (example - Uptime Kuma alerts)",
            "plugin": "webhookJson",
            "enabled": false,
            "port": 2598,
            "bind": "127.0.0.1",
            "extendedOptions": {
                "routes": [
                    {
                        "path": "/kuma",
                        "site": "kuma",
                        "plugin": "notify",
                        "descriptionFrom": "monitor.name",
                        "description": "Uptime Kuma",
                        "fields": [
                            {
                                "from": "heartbeat.status",
                                "map": {
                                    "0": "[P5]",
                                    "1": "[P4]"
                                },
                                "default": "[P3]",
                                "styleMap": {
                                    "0": 2,
                                    "1": 3
                                }
                            },
                            {
                                "from": "msg"
                            }
                        ]
                    }
                ]
            }
        }
    ]
}
