{
    "targets": [{ "location": "https://localhost:3000/FIFO", "key": "184f451d98b79137dcb014abda5eb6c9" }],
    "site": "MyOffice",
    "logLevel": "debug",


    "collectors": [
        {
            "description": "Net Watcher",
            "plugin": "hamLive",
            "enabled": false,
            "url": "https://www.ham.live/api/data/livenets",
            "pollIntervalSec": 60
        },
        {
            "description": "SRS Simulated",
            "plugin": "srsSerial",
            "path": "sim://srs",
            "baudRate": 9600,
            "keepRaw": true,
            "extendedOptions": {
                "suppress": ["COR", "CLEAR"],
                "portmap": [
                    "440",
                    "2M",
                    "L1-PV Switch",
                    "L2-South Mtn",
                    "L3-TBD-OFF",
                    "L4-Saddle",
                    "L5-Sulphur",
                    "L6-San Pedro"
                ]
            }
        },
        {
            "description": "TNC Simulated",
            "plugin": "genericSerial",
            "path": "sim://generic",
            "baudRate": 9600
        },
        {
            "description": "Real Serial Device",
            "plugin": "genericSerial",
            "path": "/dev/tty.usbmodem11401",
            "baudRate": 9600
        },
        {
            "description": "LAN Sensors",
            "plugin": "udpStruct",
            "port": 17996,
            "bind": "127.0.0.1",
            "extendedOptions": {
                "siteFromPacket": true
            }
        }

    ]
}
